# ─────────────────────────────────────────────────────────────
# ClinicFlow AI — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────
# Project URL + anon (publishable) key are safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key bypasses RLS — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by the type generation script (npm run db:types)
SUPABASE_PROJECT_ID=your-project-ref

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Vapi (voice) ─────────────────────────────────────────────
VAPI_API_KEY=your-vapi-private-key
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
# Shared secret used to verify inbound webhook signatures from Vapi.
VAPI_WEBHOOK_SECRET=generate-a-long-random-string
# For outbound missed-call recovery calls:
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_ASSISTANT_ID=your-vapi-assistant-id

# ── Google Calendar ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ── Cron / internal worker auth ──────────────────────────────
# Protects the missed-call recovery worker endpoint. Vercel Cron sends this
# automatically as a Bearer token when set as a project env var.
CRON_SECRET=generate-a-long-random-string

# ── Email notifications (optional; e.g. Resend) ──────────────
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=alerts@clinicflow.ai

# ── Local testing helper ─────────────────────────────────────
# Fallback clinic for the Vapi webhook when the called number doesn't match.
DEFAULT_CLINIC_ID=
